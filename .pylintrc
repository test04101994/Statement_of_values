[MAIN]
py-version = 3.11
persistent = no
# Resolve ``sov`` when running pylint from project root (tests/ imports).
init-hook = "import sys; sys.path.insert(0, '.')"

[FORMAT]
max-line-length = 120
indent-string = "    "

[DESIGN]
max-args = 10
max-positional-arguments = 10
max-locals = 65
max-returns = 20
max-branches = 28
max-statements = 100
max-module-lines = 2500

[MESSAGES CONTROL]
# Single-file engine is intentionally large until split into subpackages.
disable =
    duplicate-code,

[SIMILARITIES]
min-similarity-lines = 6
